# Loom Daemon Configuration
# Copy this file to .env and update the values

# Device ID (auto-generated if not set)
# LOOM_DEVICE_ID=my-device-123

# Backend WebSocket URL
LOOM_BACKEND_URL=ws://localhost:8000

# Centrifugo WebSocket URL
LOOM_CENTRIFUGO_URL=ws://localhost:8000

# Default runtime type (claude or opencode)
LOOM_RUNTIME=claude

# Control server listen address (0 means random port)
LOOM_CONTROL_ADDR=127.0.0.1:0
